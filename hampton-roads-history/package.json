{
  "name": "hampton-roads-history",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node --import tsx scripts/generate-import-map.mts",
    "build": "next build",
    "start": "next start",
    "prestart": "node scripts/prestart-migrate.mjs",
    "lint": "eslint",
    "postinstall": "patch-package",
    "migrate": "node --import tsx scripts/migrate.mts",
    "migrate:create": "node --import tsx scripts/create-migration.mts",
    "generate:types": "node --import tsx scripts/generate-types.mts",
    "seed:placements": "node --import tsx scripts/seed-placements.mts",
    "retention": "node --import tsx scripts/retention.mts",
    "aggregate:ads": "node --import tsx scripts/aggregate-ads.mts",
    "validate:supply-chain": "node --import tsx scripts/validate-supply-chain.mts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --project=chromium",
    "test:visual": "playwright test --project=visual",
    "vapornet:css": "node --import tsx scripts/generate-vapornet-css.mts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.86.0",
    "@payloadcms/next": "^3.86.0",
