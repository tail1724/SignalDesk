# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase project (public — safe to expose client-side; RLS enforces access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL — used to build absolute URLs (sitemap, RSS, OG images,
# email links, JSON-LD). Must be the real production origin in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Payload CMS 3 — direct Postgres connection (bypasses RLS entirely; this
# role can read/write everything, so treat it like a service-role key).
# Use the pooled connection string (port 6543) from Supabase's connection
# pooler, not the direct :5432 host.
DATABASE_URI=postgresql://postgres.your-project:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
PAYLOAD_SECRET=

# Resend — transactional email (newsletter confirm/welcome, correction reports)
RESEND_API_KEY=
# Must be on a domain verified in your Resend dashboard, or sends will
# fail with a from-address error. Use onboarding@resend.dev for testing
# with no domain setup.
NEWSLETTER_FROM_EMAIL=newsletter@yourdomain.com
# Where reader-submitted correction reports (POST /api/corrections) are
# forwarded for review (WS-20). Not stored in the database — an editor
# reviews the email and publishes a hr_corrections entry via Payload once verified.
CORRECTIONS_EMAIL=corrections@yourdomain.com

# HMAC secrets — generate with `openssl rand -hex 32`. Rotate by:
#   1. Generate a new value, deploy it alongside the old one accepted
#      (add a brief dual-secret window in verifyWebhookSignature/verifyAdToken
#      if a rotation needs zero downtime), or accept a short window where
#      in-flight webhook calls signed with the old secret will 401.
#   2. Update this value in the deployment environment (Coolify env vars).
#   3. Redeploy. Any request signed with the old secret after this point
#      is rejected — by design, this invalidates anything an attacker may
#      have captured.
AD_HMAC_SECRET=
WEBHOOK_SECRET=
