# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase project (public — safe to expose client-side; RLS enforces access)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — same trust tier as DATABASE_URI, never expose
# client-side. Used by scripts/retention.mts (lib/supabase/service.ts) to
# purge expired hr_page_events/hr_ad_impressions/hr_silver_article_sessions
# rows on a schedule.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical site URL — used to build absolute URLs (sitemap, RSS, OG images,
# email links, JSON-LD). Must be the real production origin in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Payload CMS 3 — direct Postgres connection (bypasses RLS entirely; this
# role can read/write everything, so treat it like a service-role key).
# Payload runs a persistent Node server, so use a persistent-friendly
# connection: the DIRECT connection (db.<ref>.supabase.co:5432, IPv6-only) or,
# where IPv6 isn't available, the SESSION pooler (…pooler.supabase.com:5432).
# Do NOT use the transaction pooler (:6543) — it doesn't support the prepared
# statements Payload/Drizzle rely on.
DATABASE_URI=postgresql://postgres.your-project:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres
PAYLOAD_SECRET=

# Resend — transactional email (newsletter confirm/welcome, correction reports)
RESEND_API_KEY=
# Must be on a domain verified in your Resend dashboard, or sends will
# fail with a from-address error. Use onboarding@resend.dev for testing
# with no domain setup.
NEWSLETTER_FROM_EMAIL=newsletter@yourdomain.com
# Where reader-submitted correction reports (POST /api/corrections) are
# forwarded for review (WS-20). Not stored in the database — an editor
# reviews the email and publishes a hr_corrections entry via Payload once verified.
CORRECTIONS_EMAIL=corrections@yourdomain.com

# HMAC secrets — generate with `openssl rand -hex 32`. Rotate by:
#   1. Generate a new value, deploy it alongside the old one accepted
#      (add a brief dual-secret window in verifyWebhookSignature/verifyAdToken
#      if a rotation needs zero downtime), or accept a short window where
#      in-flight webhook calls signed with the old secret will 401.
#   2. Update this value in the deployment environment (Coolify env vars).
#   3. Redeploy. Any request signed with the old secret after this point
#      is rejected — by design, this invalidates anything an attacker may
#      have captured.
AD_HMAC_SECRET=
WEBHOOK_SECRET=

# Seed Refiner / Hunt's Pointe — server-to-server draft ingestion. This URL is
# used by the newsroom's "Open Seed Refiner" button and provenance receipts.
# WEBHOOK_SECRET signs requests; Idempotency-Key prevents duplicate drafts.
SEED_REFINER_ORIGIN=https://seed-refiner.lovable.app/

# Governance launch gates. The admin dashboard intentionally reports these as
# incomplete until the corresponding production controls are configured.
#
# CONSENT_ENFORCEMENT: the consent center (components/ConsentCenter.tsx,
# lib/consent.ts) always enforces the gate — ad requests, event beacons, and
# session-id storage stay off until a reader resolves consent, regardless of
# this flag. Setting it to "enabled" only flips the dashboard's status pill
# once a human has verified that behavior end-to-end in staging.
# RETENTION_JOBS_ENABLED: scripts/retention.mts is real and runnable
# (`npm run retention` — dry run by default, `-- --execute` to delete) once
# SUPABASE_SERVICE_ROLE_KEY is set; set this to "true" once it's on a
# schedule (a Coolify scheduled task) so the dashboard reflects reality.
CONSENT_ENFORCEMENT=disabled
RETENTION_JOBS_ENABLED=false
ADS_TXT_CONTENT=
SELLERS_JSON_CONTENT=

# Supabase Storage S3-compatible endpoint — backs the hr_media upload
# collection via @payloadcms/storage-s3 (payload.config.ts). Endpoint is the
# project's S3 gateway; access key/secret are the project's S3 access keys
# (Supabase dashboard → Storage → S3 connection). Bucket is "hr-media".
SUPABASE_S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=

# Epic Y ad experiment (standard vs revenue placement policy). Off by default —
# the revenue arm is the only ad-density increase in the system and must not
# ship before the Epic L launch experiment. NEXT_PUBLIC_ (read client-side,
# baked at build time). Set to "1" only when deliberately enabling the launch
# experiment.
NEXT_PUBLIC_ADS_REVENUE_EXPERIMENT=0
